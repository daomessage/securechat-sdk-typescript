{
  "name": "@daomessage_sdk/sdk",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.3.0",
  "description": "SecureChat End-to-End Encrypted Messaging SDK",
  "author": "Daomessage Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/daomessage/securechat-sdk-typescript.git"
  },
  "homepage": "https://github.com/daomessage/securechat-sdk-typescript#readme",
  "bugs": {
    "url": "https://github.com/daomessage/securechat-sdk-typescript/issues"
  },
  "keywords": [
    "daomessage",
    "securechat",
    "e2ee",
    "end-to-end encryption",
    "messaging",
    "websocket",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./reactive": {
      "types": "./dist/index-reactive.d.ts",
      "import": "./dist/index-reactive.js",
      "require": "./dist/index-reactive.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@scure/bip39": "^1.3.0",
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
